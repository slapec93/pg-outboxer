{
  "dashboard": {
    "title": "pg-outboxer Overview",
    "uid": "pg-outboxer",
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Events Processed (Rate)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(pg_outboxer_events_processed_total{outcome=\"success\"}[1m])",
            "legendFormat": "Success",
            "refId": "A"
          },
          {
            "expr": "rate(pg_outboxer_events_processed_total{outcome=\"failed_retryable\"}[1m])",
            "legendFormat": "Failed (Retryable)",
            "refId": "B"
          },
          {
            "expr": "rate(pg_outboxer_events_processed_total{outcome=\"failed_fatal\"}[1m])",
            "legendFormat": "Failed (Fatal)",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Events/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(pg_outboxer_events_processed_total{outcome=~\"failed.*\"}[1m])) / sum(rate(pg_outboxer_events_processed_total[1m])) * 100",
            "legendFormat": "Error %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "max": 100, "min": 0},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "Publish Latency (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(pg_outboxer_publish_duration_seconds_bucket[1m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(pg_outboxer_publish_duration_seconds_bucket[1m]))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(pg_outboxer_publish_duration_seconds_bucket[1m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "title": "Publisher Success Rate by Publisher",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(pg_outboxer_events_published_total{status=\"success\"}[1m])",
            "legendFormat": "{{publisher}} - Success",
            "refId": "A"
          },
          {
            "expr": "rate(pg_outboxer_events_published_total{status=\"error\"}[1m])",
            "legendFormat": "{{publisher}} - Error",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ops"},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "Active Workers",
        "type": "singlestat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "pg_outboxer_active_workers",
            "refId": "A"
          }
        ],
        "format": "none"
      },
      {
        "id": 6,
        "title": "Total Events Processed",
        "type": "singlestat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
        "targets": [
          {
            "expr": "sum(pg_outboxer_events_processed_total)",
            "refId": "A"
          }
        ],
        "format": "none"
      },
      {
        "id": 7,
        "title": "Dead Letter Events",
        "type": "singlestat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "pg_outboxer_dead_letter_events_total",
            "refId": "A"
          }
        ],
        "format": "none",
        "colors": ["#299c46", "#e0b400", "#d44a3a"],
        "thresholds": "1,10"
      },
      {
        "id": 8,
        "title": "Retry Distribution",
        "type": "graph",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
        "targets": [
          {
            "expr": "rate(pg_outboxer_event_retries_total[1m])",
            "legendFormat": "Retry {{retry_count}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops"},
          {"format": "short"}
        ]
      }
    ]
  }
}
